# Docker忽略文件 - 优化构建速度和镜像大小

# 版本控制
.git
.gitignore
.gitattributes
.github

# Docker 相关
Dockerfile
docker-compose.yml
.dockerignore

# 依赖目录
node_modules
server/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 构建输出
dist
build
.out
.next
.nuxt

# 测试相关
coverage
.nyc_output
*.lcov

# 环境文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 日志文件
