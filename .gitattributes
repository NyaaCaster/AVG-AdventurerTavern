# 自动检测文本文件并规范化行尾
* text=auto

# Shell 脚本使用 LF
*.sh text eol=lf

# PowerShell 脚本使用 CRLF
*.ps1 text eol=crlf

# Windows 批处理文件使用 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 源代码文件使用 LF
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Docker 文件使用 LF
Dockerfile* text eol=lf
*.conf text eol=lf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp3 binary
*.mp4 binary
*.wav binary
*.db binary
*.sqlite binary