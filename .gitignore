# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Google AI Studio metadata
metadata.json

# Database files
data/database.sqlite
data/*.sqlite
database-server/data/
database-server/*.sqlite

# SSL Certificates (私密文件，不提交到仓库)
# 保留 SSL 目录结构，但排除所有证书文件
SSL/*
!SSL/.gitkeep
database-server/SSL/*
!database-server/SSL/.gitkeep

# Continue IDE 配置
# 提交团队共享的配置文件，排除个人数据
.continue/prompts/          # 排除对话历史
.continue/.continuerc.json  # 排除个人设置
.continue/config.json.local # 排除本地配置覆盖

# 保留这些文件在版本管理中：
# .continue/config.json  - AI 助手配置（团队共享）
# .continue/README.md   - 使用说明文档（团队共享）

# GitHub Actions 日志目录
# 保留目录结构，但排除所有日志文件
.github/workflows/job-logs/*
!.github/workflows/job-logs/.gitkeep

# 设计及外部设计参考资料文档目录
.DesDoc/

# Trae IDE 规则和技能目录（提交到 GitHub，方便跨设备使用）
# .trae/rules/ 和 .trae/skills/ 不再排除

# 环境变量文件（包含敏感信息）
.env
.env.local
.env.*.local
.env.example
database-server/.env
database-server/.env.local



