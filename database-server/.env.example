# Discord OAuth 配置
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here
DISCORD_REDIRECT_URI=https://yourdomain.com:3097/auth/discord/callback

# ============ 登录系统模式（二选一，唯一生效）============
# password = 账号密码登录系统  |  discord = Discord OAuth 登录系统
# 此开关决定唯一生效的登录方式，切换后另一套登录系统对用户完全不可见。
AUTH_MODE=password
# 启用 Discord 登录系统时，注释上面一行并改用下面这行：
# AUTH_MODE=discord

# 数据库路径（生产环境使用 Docker 卷路径）
DB_PATH=/app/data/database.sqlite

# 前端 URL
FRONTEND_URL=https://yourdomain.com

# ============ NyaaAcount 统一账号平台（凭证转发）============
# 登录/注册/改密经此调用 NyaaAcount /api/project/*
# token / key 与 NyaaAcount .env 中的 *_AVG 项一致
NYAAACOUNT_PUBLIC_URL=http://h.nyaa.host:5110
NYAAACOUNT_API_TOKEN=your_project_token_here
NYAAACOUNT_ENCRYPTION_KEY=your_32byte_hex_key_here
